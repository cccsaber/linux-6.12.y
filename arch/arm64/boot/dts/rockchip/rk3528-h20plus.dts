			};

			emmc-strb {
				rockchip,pins = <0x01 0x1f 0x01 0x0e>;
				phandle = <0x59>;
			};
		};

		eth {

			eth-pins {
				rockchip,pins = <0x03 0x0d 0x02 0x10>;
				phandle = <0xb0>;
			};
		};

		fephy {

			fephym0-led-dpx {
				rockchip,pins = <0x04 0x0d 0x02 0x0e>;
				phandle = <0xb1>;
			};

			fephym0-led-link {
				rockchip,pins = <0x04 0x10 0x02 0x0e>;
				phandle = <0x4a>;
			};

			fephym0-led-spd {
				rockchip,pins = <0x04 0x0f 0x02 0x0e>;
				phandle = <0x4b>;
			};

			fephym1-led-dpx {
				rockchip,pins = <0x02 0x04 0x05 0x0e>;
				phandle = <0xb2>;
			};

			fephym1-led-link {

		};

		hsm {

			hsmm0-pins {
				rockchip,pins = <0x02 0x02 0x04 0x0e>;
				phandle = <0xba>;
			};

			hsmm1-pins {
				rockchip,pins = <0x01 0x04 0x03 0x0e>;
				phandle = <0xbb>;
			};
		};

		i2c0 {

			i2c0m0-xfer {
				rockchip,pins = <0x04 0x14 0x02 0x11 0x04 0x13 0x02 0x11>;
				phandle = <0xbc>;
			};

			i2c0m1-xfer {
				rockchip,pins = <0x04 0x01 0x02 0x11 0x04 0x00 0x02 0x11>;
				phandle = <0xbd>;
			};
		};

		i2c1 {

			i2c1m0-xfer {
				rockchip,pins = <0x04 0x03 0x02 0x11 0x04 0x02 0x02 0x11>;
				phandle = <0xbe>;

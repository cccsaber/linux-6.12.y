			tx-queues-config {
				snps,tx-queues-to-use = <0x01>;
				phandle = <0x4e>;

				queue0 {
				};
			};
		};

		mmc@ffbf0000 {
			compatible = "rockchip,rk3528-dwcmshc\0rockchip,rk3588-dwcmshc";
			reg = <0x00 0xffbf0000 0x00 0x10000>;
			assigned-clocks = <0x0b 0x8f 0x0b 0x90 0x0b 0x8c>;
			assigned-clock-rates = <0x17d7840 0x16e3600 0x17d7840>;
			clocks = <0x0b 0x8c 0x0b 0x8d 0x0b 0x8e 0x0b 0x8f 0x0b 0x90>;
			clock-names = "core\0bus\0axi\0block\0timer";
			interrupts = <0x00 0x88 0x04>;
			max-frequency = <0x17d7840>;
			pinctrl-names = "default";
			pinctrl-0 = <0x57 0x58 0x59 0x5a>;
			power-domains = <0x0d 0x08>;
			resets = <0x0b 0x41 0x0b 0x42 0x0b 0x43 0x0b 0x44 0x0b 0x45>;
			reset-names = "core\0bus\0axi\0block\0timer";
			status = "okay";
			bus-width = <0x08>;
			no-sd;
			no-sdio;
			non-removable;
			/* HS200/HS400 disabled for stability */
			/* mmc-hs200-1_8v; */
			/* mmc-hs200-enhanced-strobe; */
			phandle = <0x162>;
		};

		spi@ffc00000 {
			compatible = "rockchip,sfc";
			reg = <0x00 0xffc00000 0x00 0x4000>;
			clocks = <0x0b 0x8b 0x0b 0x8a>;
			clock-names = "clk_sfc\0hclk_sfc";
			interrupts = <0x00 0x87 0x04>;
			power-domains = <0x0d 0x08>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			status = "disabled";
			phandle = <0x163>;
		};

		mmc@ffc10000 {
			compatible = "rockchip,rk3528-dw-mshc\0rockchip,rk3288-dw-mshc";
			reg = <0x00 0xffc10000 0x00 0x4000>;
			clocks = <0x0b 0xb9 0x0b 0xb8 0x0b 0x197 0x0b 0x198>;
			clock-names = "biu\0ciu\0ciu-drive\0ciu-sample";
			fifo-depth = <0x100>;
			interrupts = <0x00 0x89 0x04>;
			max-frequency = <0x5f5e100>;
			pinctrl-names = "default";
			pinctrl-0 = <0x5b 0x5c 0x5d>;
			power-domains = <0x0d 0x08>;
			resets = <0x0b 0x67>;
			reset-names = "reset";
			status = "okay";
			no-sd;
			no-mmc;
			supports-sdio;
			bus-width = <0x04>;
			disable-wp;
			cap-sd-highspeed;
			cap-sdio-irq;
			keep-power-in-suspend;
			non-removable;
			mmc-pwrseq = <0x17b>;
			sd-uhs-sdr104;

			/* --- 新增：Linux 6.12 必须的供电声明 --- */
			vmmc-supply = <0x65>;   /* 引用 vcc_sd (3.3V) */
			vqmmc-supply = <0x66>;  /* 引用 vccio_sd (1.8V动态切换) */

			phandle = <0x164>;
		};

		mmc@ffc20000 {
			compatible = "rockchip,rk3528-dw-mshc\0rockchip,rk3288-dw-mshc";
			reg = <0x00 0xffc20000 0x00 0x4000>;
			clocks = <0x0b 0xbb 0x0b 0xba 0x0b 0x199 0x0b 0x19a>;
			clock-names = "biu\0ciu\0ciu-drive\0ciu-sample";
			fifo-depth = <0x100>;
			interrupts = <0x00 0x8a 0x04>;
			max-frequency = <0xbebc200>;
			pinctrl-names = "default";
			pinctrl-0 = <0x5e 0x5f 0x60>;
			power-domains = <0x0d 0x08>;
			resets = <0x0b 0x68>;
			reset-names = "reset";
			status = "disabled";
			phandle = <0x165>;
		};

		mmc@ffc30000 {
			compatible = "rockchip,rk3528-dw-mshc\0rockchip,rk3288-dw-mshc";
			reg = <0x00 0xffc30000 0x00 0x4000>;
			clocks = <0x0b 0x128 0x0b 0x127 0x0b 0x195 0x0b 0x196>;
			clock-names = "biu\0ciu\0ciu-drive\0ciu-sample";
			fifo-depth = <0x100>;
			interrupts = <0x00 0x85 0x04>;
			max-frequency = <0x8f0d180>;
			pinctrl-names = "default";
			pinctrl-0 = <0x61 0x62 0x63 0x64>;
			power-domains = <0x0d 0x07>;
			resets = <0x0b 0xbd>;
			reset-names = "reset";
			rockchip,default-sample-phase = <0x5a>;
			status = "okay";
			bus-width = <0x04>;
			cap-mmc-highspeed;
			cap-sd-highspeed;
			disable-wp;
			supports-sd;
			sd-uhs-sdr12;
			sd-uhs-sdr25;
			sd-uhs-sdr50;
			sd-uhs-sdr104;
			vmmc-supply = <0x65>;
			vqmmc-supply = <0x66>;
			phandle = <0x166>;
		};

		nvmem@ffce0000 {
			compatible = "rockchip,rk3528-otp";
			reg = <0x00 0xffce0000 0x00 0x4000>;
			clocks = <0x0b 0x12b 0x0b 0x129 0x0b 0x12a>;
			clock-names = "otp\0apb_pclk\0sbpi";
			resets = <0x0b 0xc0 0x0b 0xbe 0x0b 0xbf>;
			reset-names = "otp\0apb\0sbpi";
			phandle = <0x167>;

			nvmem-layout {
				compatible = "fixed-layout";
				#address-cells = <0x01>;
				#size-cells = <0x01>;

				cpu-code@2 {
					reg = <0x02 0x02>;
					phandle = <0x168>;
				};

				cpu-version@8 {
					reg = <0x08 0x01>;
					bits = <0x03 0x03>;
					phandle = <0x169>;
				};

				id@a {
					reg = <0x0a 0x10>;
					phandle = <0x16a>;
				};

				cpu-leakage@1a {
					reg = <0x1a 0x01>;
					phandle = <0x16b>;
				};

				logic-leakage@1b {
					reg = <0x1b 0x01>;
					phandle = <0x16c>;
				};

				gpu-leakage@1c {
					reg = <0x1c 0x01>;
					phandle = <0x16d>;
				};

				tsadc-trim@44 {
					reg = <0x44 0x02>;
					bits = <0x00 0x0a>;
					phandle = <0x43>;
				};
			};
		};

		dma-controller@ffd60000 {
			compatible = "arm,pl330\0arm,primecell";
			reg = <0x00 0xffd60000 0x00 0x4000>;
			clocks = <0x0b 0x5e>;
			clock-names = "apb_pclk";
			interrupts = <0x00 0x00 0x04 0x00 0x01 0x04 0x00 0x02 0x04 0x00 0x03 0x04 0x00 0x04 0x04 0x00 0x05 0x04 0x00 0x06 0x04 0x00 0x07 0x04 0x00 0x10 0x04>;
			#dma-cells = <0x01>;
			arm,pl330-periph-burst;
			phandle = <0x3b>;
		};

		phy@ffdc0000 {
			compatible = "rockchip,rk3528-naneng-combphy";
			reg = <0x00 0xffdc0000 0x00 0x10000>;
			assigned-clocks = <0x0b 0x7b>;
			assigned-clock-rates = <0x5f5e100>;
			clocks = <0x0b 0x7b 0x0b 0xb3 0x0b 0xb4>;
			clock-names = "ref\0apb\0pipe";
			power-domains = <0x0d 0x08>;
			resets = <0x0b 0x63 0x0b 0x65>;
			reset-names = "phy\0apb";
			#phy-cells = <0x01>;
			rockchip,pipe-grf = <0x42>;
			rockchip,pipe-phy-grf = <0x67>;
			status = "okay";
			phandle = <0x19>;
		};

		/*
		 * HDMI stack migrated from rk3528-h28k.dts.
		 * Keep these nodes grouped together for easier maintenance.
		 * Other existing nodes are intentionally untouched.
		 */
		display-subsystem {
			compatible = "rockchip,display-subsystem";
			ports = <&vop_out>;
			status = "okay";

			route {
				route-hdmi {
					status = "okay";
					logo,uboot = "logo.bmp";
					logo,kernel = "logo_kernel.bmp";
					logo,mode = "center";
					charge_logo,mode = "center";
					connect = <&vp0_out_hdmi>;
				};
			};
		};

		vop@ff840000 {
			compatible = "rockchip,rk3528-vop";
			reg = <0x00 0xff840000 0x00 0x3000 0x00 0xff845000 0x00 0x1000 0x00 0xff846400 0x00 0x800>;
			reg-names = "regs\0gamma_lut\0acm_regs";
			interrupts = <0x00 0x6d 0x04>;
			clocks = <0x0b 0x105 0x0b 0x102 0x0b 0x103 0x0b 0x104>;
			clock-names = "aclk_vop\0hclk_vop\0dclk_vp0\0dclk_vp1";
			assigned-clocks = <0x0b 0x103>;
			assigned-clock-parents = <&inno_hdmiphy_clk>;
			iommus = <&vop_mmu>;
			rockchip,grf = <0x46>;
			status = "okay";

			ports {
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				vop_out: port@0 {
					reg = <0x00>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;

					vp0_out_hdmi: endpoint@2 {
						reg = <0x02>;
						remote-endpoint = <&hdmi_in_vp0>;
					};
				};
			};
		};

		vop_mmu: iommu@ff847e00 {
			compatible = "rockchip,iommu-v2";
			reg = <0x00 0xff847e00 0x00 0x100>;
			interrupts = <0x00 0x6d 0x04>;
			interrupt-names = "vop_mmu";
			clocks = <0x0b 0x105 0x0b 0x102>;
			clock-names = "aclk\0iface";
			#iommu-cells = <0x00>;
			rockchip,disable-device-link-resume;
			rockchip,shootdown-entire;
			status = "disabled";
		};

		hdcp2@ff8c0000 {
			compatible = "rockchip,rk3528-hdmi-hdcp2";
			reg = <0x00 0xff8c0000 0x00 0x2000>;
			interrupts = <0x00 0x68 0x04>;
			clocks = <0x0b 0x10e 0x0b 0x110 0x0b 0x10f>;
			clock-names = "aclk_hdcp2\0pclk_hdcp2\0hdcp2_clk_hdmi";
			status = "disabled";
		};

		hdmi@ff8d0000 {
			compatible = "rockchip,rk3528-dw-hdmi";
			reg = <0x00 0xff8d0000 0x00 0x20000 0x00 0xff610000 0x00 0x200>;
			interrupts = <0x00 0x66 0x04 0x00 0x67 0x04>;
			interrupt-names = "hdmi\0hdmi_wakeup";
			clocks = <0x0b 0x106 0x0b 0x107 0x0b 0x108 &inno_hdmiphy_clk>;
			clock-names = "iahb\0isfr\0cec\0dclk_vp0";
			ddc-i2c-scl-high-time-ns = <0x2599>;
			ddc-i2c-scl-low-time-ns = <0x2710>;
			reg-io-width = <0x04>;
			rockchip,grf = <0x46>;
			rockchip,cts-manual;
			pinctrl-names = "default";
			pinctrl-0 = <0xb9>;
			phys = <&hdmiphy>;
			phy-names = "hdmi";
			avdd-0v9-supply = <0x175>;
			avdd-1v8-supply = <0x44>;
			#sound-dai-cells = <0x00>;
			hpd-gpios = <0x71 0x02 0x00>;
			status = "okay";

			ports {
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				port@0 {
					reg = <0x00>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;

					hdmi_in_vp0: endpoint@0 {
						reg = <0x00>;
						remote-endpoint = <&vp0_out_hdmi>;
						status = "okay";
					};
				};

				port@1 {
					reg = <0x01>;

					hdmi_out_con: endpoint {
						remote-endpoint = <&hdmi_con_in>;
					};
				};
			};
		};

		hdmiphy: hdmiphy@ffe00000 {
			compatible = "rockchip,rk3528-hdmi-phy";
			reg = <0x00 0xffe00000 0x00 0x10000>;
			interrupts = <0x00 0x65 0x04>;
			#phy-cells = <0x00>;
			clocks = <0x0b 0x10c 0x20>;
			clock-names = "sysclk\0refclk";
			status = "okay";

			inno_hdmiphy_clk: clk-port {
				#clock-cells = <0x00>;
				clock-output-names = "clk_hdmiphy_pixel_io";
				status = "okay";
			};
		};

		usb2phy@ffdf0000 {
			compatible = "rockchip,rk3528-usb2phy";
			reg = <0x00 0xffdf0000 0x00 0x10000>;
			clocks = <0x0b 0x137 0x0b 0x136>;
			clock-names = "phyclk\0pclk";
			#clock-cells = <0x00>;
			clock-output-names = "clk_usbphy_480m";
			power-domains = <0x0d 0x07>;
			rockchip,usbgrf = <0x46>;
			status = "okay";
			phandle = <0x1d>;

			otg-port {
				interrupts = <0x00 0x92 0x04 0x00 0x93 0x04 0x00 0x94 0x04>;
				interrupt-names = "otg-bvalid\0otg-id\0linestate";
				#phy-cells = <0x00>;
				status = "okay";
				vbus-supply = <0x68>;
				phandle = <0x1e>;
			};

			host-port {
				interrupts = <0x00 0x96 0x04>;
				interrupt-names = "linestate";
				#phy-cells = <0x00>;
				status = "okay";
				phy-supply = <0x68>;
				phandle = <0x1f>;
			};
		};
	};

	adc-keys {
		status = "okay";
		compatible = "adc-keys";
		io-channels = <0x69 0x00>;
		io-channel-names = "buttons";
		keyup-threshold-microvolt = <0x1b7740>;
		poll-interval = <0x64>;
		phandle = <0x16e>;

		vol-up-key {
			label = "volume up";
			linux,code = <0x73>;
			press-threshold-microvolt = <0x6d6>;
		};
	};

	chosen {
		stdout-path = "serial0:1500000n8";
		phandle = <0x16f>;
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-names = "led-green\0led-amber\0led-blue";
		pinctrl-0 = <0x6a 0x6b 0x6c>;
		phandle = <0x170>;

		led-green {
			label = "led_green";
			gpios = <0x1a 0x0f 0x01>;
			linux,default-trigger = "heartbeat";
			phandle = <0x171>;
		};

		led-amber {
			label = "led_amber";
			gpios = <0x1a 0x11 0x01>;
			phandle = <0x172>;
		};

		led-blue {
			label = "led_blue";
			gpios = <0x1a 0x10 0x01>;
			phandle = <0x173>;
		};
	};

	vcc12v-dcin {
		compatible = "regulator-fixed";
		regulator-name = "vcc12v-dcin";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0xb71b00>;
		regulator-max-microvolt = <0xb71b00>;
		phandle = <0x6d>;
	};

	vcc5v0-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		vin-supply = <0x6d>;
		phandle = <0x68>;
	};

	vcc-3v3-s3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3_s3";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		vin-supply = <0x68>;
		phandle = <0x1b>;
	};

	vdd-1v8-s3 {
		compatible = "regulator-fixed";
		regulator-name = "vdd_1v8_s3";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		vin-supply = <0x68>;
		phandle = <0x44>;
	};

	vcc-ddr-s3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_ddr_s3";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x124f80>;
		regulator-max-microvolt = <0x124f80>;
		vin-supply = <0x68>;
		phandle = <0x174>;
	};

	vdd-0v9-s3 {
		compatible = "regulator-fixed";
		regulator-name = "vdd_0v9_s3";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0xdbba0>;
		regulator-max-microvolt = <0xdbba0>;
		vin-supply = <0x68>;
		phandle = <0x175>;
	};

	vdd-logic {
		compatible = "pwm-regulator";
		pwms = <0x6e 0x00 0x1388 0x01>;
		regulator-name = "vdd_logic";
		regulator-min-microvolt = <0xac1e8>;
		regulator-max-microvolt = <0xf59b0>;
		regulator-init-microvolt = <0xe7ef0>;
		regulator-always-on;
		regulator-boot-on;
		regulator-settling-time-up-us = <0xfa>;
		pwm-supply = <0x68>;
		status = "okay";
		phandle = <0x39>;
	};

	vdd-arm {
		compatible = "pwm-regulator";
		pwms = <0x6f 0x00 0x1388 0x01>;
		regulator-name = "vdd_arm";
		regulator-min-microvolt = <0xb6210>;
		regulator-max-microvolt = <0x125368>;
		regulator-init-microvolt = <0xe8aa8>;
		regulator-always-on;
		regulator-boot-on;
		regulator-settling-time-up-us = <0xfa>;
		regulator-enable-ramp-delay = <0x190>;
		regulator-ramp-delay = <0x30d4>;
		pwm-supply = <0x68>;
		status = "okay";
		phandle = <0x08>;
	};

	sdio-pwrseq {
		compatible = "mmc-pwrseq-simple";
		pinctrl-names = "default";
		pinctrl-0 = <0x17e 0x177>;
		post-power-on-delay-ms = <0xc8>;
		reset-gpios = <0x72 0x06 0x01>;
		status = "okay";
		phandle = <0x17b>;
	};


	vcc-sd {
		compatible = "regulator-fixed";
		gpio = <0x1a 0x01 0x01>;
		regulator-name = "vcc_sd";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		vin-supply = <0x1b>;
		phandle = <0x65>;
	};

	vccio-sd {
		compatible = "regulator-gpio";
		regulator-name = "vccio_sd";
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x325aa0>;
		gpios = <0x1a 0x0e 0x00>;
		vin-supply = <0x68>;
		states = <0x1b7740 0x00 0x325aa0 0x01>;
		phandle = <0x66>;
	};

	gpio-keys {
		compatible = "gpio-keys";
		status = "okay";
		phandle = <0x176>;

		key-factory {
			debounce-interval = <0x64>;
			gpios = <0x1a 0x0d 0x01>;
			label = "Reset Button";
			linux,code = <0x198>;
		};
	};

	hdmi-con {
		compatible = "hdmi-connector";
		type = "a";
		label = "HDMI";

		port {
			hdmi_con_in: endpoint {
				remote-endpoint = <&hdmi_out_con>;
			};
		};
	};

	__symbols__ {
		cpu0 = "/cpus/cpu@0";
		cpu1 = "/cpus/cpu@1";
		cpu2 = "/cpus/cpu@2";
		cpu3 = "/cpus/cpu@3";
		scmi = "/firmware/scmi";
		scmi_clk = "/firmware/scmi/protocol@14";
		cpu_opp_table = "/opp-table-cpu";
		gpu_opp_table = "/opp-table-gpu";
		pinctrl = "/pinctrl";
		gpio0 = "/pinctrl/gpio@ff610000";
		gpio1 = "/pinctrl/gpio@ffaf0000";
		gpio2 = "/pinctrl/gpio@ffb00000";
		gpio3 = "/pinctrl/gpio@ffb10000";
		gpio4 = "/pinctrl/gpio@ffb20000";
		pcfg_pull_up = "/pinctrl/pcfg-pull-up";
		pcfg_pull_down = "/pinctrl/pcfg-pull-down";
		pcfg_pull_none = "/pinctrl/pcfg-pull-none";
		pcfg_pull_none_drv_level_0 = "/pinctrl/pcfg-pull-none-drv-level-0";
		pcfg_pull_none_drv_level_1 = "/pinctrl/pcfg-pull-none-drv-level-1";
		pcfg_pull_none_drv_level_2 = "/pinctrl/pcfg-pull-none-drv-level-2";
		pcfg_pull_none_drv_level_3 = "/pinctrl/pcfg-pull-none-drv-level-3";
		pcfg_pull_none_drv_level_4 = "/pinctrl/pcfg-pull-none-drv-level-4";
		pcfg_pull_none_drv_level_5 = "/pinctrl/pcfg-pull-none-drv-level-5";

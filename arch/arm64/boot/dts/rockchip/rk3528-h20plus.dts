			};
		};

		fspi {

			fspi-pins {
				rockchip,pins = <0x01 0x1d 0x02 0x0e 0x01 0x14 0x02 0x0e 0x01 0x15 0x02 0x0e 0x01 0x16 0x02 0x0e 0x01 0x17 0x02 0x0e>;

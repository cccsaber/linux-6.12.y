		pcfg-output-high {
			output-high;
			phandle = <0xaa>;
		};

		pcfg-output-low {
			output-low;
			phandle = <0xab>;
		};

		arm {

			arm-pins {
				rockchip,pins = <0x04 0x14 0x03 0x0e>;
				phandle = <0xac>;
			};
		};

		clk {

			clkm0-32k-out {
				rockchip,pins = <0x03 0x13 0x03 0x0e>;
				phandle = <0xad>;
			};

			clkm1-32k-out {
				rockchip,pins = <0x01 0x13 0x01 0x0e>;
				phandle = <0xae>;
			};
		};

		emmc {

			emmc-rstnout {
				rockchip,pins = <0x01 0x1e 0x01 0x0e>;
				phandle = <0xaf>;
			};

			emmc-bus8 {
				rockchip,pins = <0x01 0x14 0x01 0x0f 0x01 0x15 0x01 0x0f 0x01 0x16 0x01 0x0f 0x01 0x17 0x01 0x0f 0x01 0x18 0x01 0x0f 0x01 0x19 0x01 0x0f 0x01 0x1a 0x01 0x0f 0x01 0x1b 0x01 0x0f>;
				phandle = <0x5a>;
			};

			emmc-clk {
				rockchip,pins = <0x01 0x1d 0x01 0x0f>;
